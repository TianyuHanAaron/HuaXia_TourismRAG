APP_NAME="HuaXia Tourism RAG"

# Streamlit frontend
# Local default is http://127.0.0.1:8000. Set this to the deployed FastAPI HTTPS URL
# in Streamlit Community Cloud secrets or local env when deploying the frontend.
STREAMLIT_API_BASE_URL=

# Frontend prototype assets
SKETCHFAB_API_TOKEN=

# Agent
TOURISM_AGENT_PROVIDER=pydantic_ai
TOURISM_AGENT_MODEL=openai-chat:gpt-5.5
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ADMIN_KEY=

# Qwen Cloud / DashScope option for hackathon deployment.
# When using this path, set:
# TOURISM_AGENT_PROVIDER=qwen_cloud
# TOURISM_AGENT_MODEL=qwen3.7-max
# EMBEDDING_PROVIDER=qwen_cloud
# EMBEDDING_MODEL=text-embedding-v4
# ENABLE_MODEL_RERANKER=false
DASHSCOPE_API_KEY=your_qwen_cloud_dashscope_key_here
QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ASR_MODEL=qwen3-asr-flash

# Search API
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Web parsing
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tourism_internal_docs
QDRANT_UPSERT_BATCH_SIZE=32
QDRANT_TIMEOUT_SECONDS=120

# Session state
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400
JOB_TTL_SECONDS=86400
JOB_EXECUTION_MODE=background
JOB_QUEUE_KEY=tourism:job_queue:travel

# Production speed controls
ENABLE_RETRIEVAL_CACHE=true
RETRIEVAL_CACHE_TTL_SECONDS=3600
RETRIEVAL_TASK_CONCURRENCY=3
INTERNAL_RAG_CONCURRENCY=3
WEB_SEARCH_CONCURRENCY=3
PAGE_READ_CONCURRENCY=3
EMBEDDING_TIMEOUT_SECONDS=20
WEB_SEARCH_TIMEOUT_SECONDS=20
PAGE_READ_TIMEOUT_SECONDS=30
EMBEDDING_CIRCUIT_BREAKER_SECONDS=60
ENABLE_PLANNING_CACHE=true
PLANNING_CACHE_TTL_SECONDS=1800
ENABLE_ANSWER_CACHE=false
ANSWER_CACHE_TTL_SECONDS=900
ENABLE_GENERAL_DEEP_JOBS=true
ENABLE_PROMPT_COMPACTION=true
MAX_FINAL_CONTEXT_QUOTES_CONCISE=6
MAX_FINAL_CONTEXT_QUOTES_STANDARD=10
MAX_FINAL_CONTEXT_QUOTES_DEEP=16
ENABLE_EVIDENCE_PACK_CACHE=true
EVIDENCE_PACK_CACHE_TTL_SECONDS=1800
ENABLE_PROVIDER_BUDGETS=true
TAVILY_MAX_CALLS_PER_REQUEST=4
FIRECRAWL_MAX_CALLS_PER_REQUEST=4
PAGE_READ_MAX_CALLS_PER_REQUEST=6
PROVIDER_COOLDOWN_SECONDS=180
TOPIC_SECTION_MODE=async_for_deep
TOPIC_SECTION_CACHE_TTL_SECONDS=1800
TOPIC_SECTION_MODEL=qwen3.6-plus

# Retrieval models
# Local embedding/reranking loads large ML packages. On 512 MiB deployment
# targets, use EMBEDDING_PROVIDER=qwen_cloud or remote and keep
# ENABLE_MODEL_RERANKER=false.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSIONS=1024
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_DELAY_SECONDS=0.5
EMBEDDING_BATCH_SIZE=4
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_MODEL_RERANKER=false
MAX_MODEL_RERANK_CANDIDATES=6

# Retrieval limits
MAX_SEARCH_RESULTS=8
MAX_PAGES_TO_READ=6
TOP_K_CONTEXTS=4
MIN_RERANKER_SCORE=0.05

# External MCP service enrichment
# Disabled by default until each provider's exact MCP transport contract is confirmed.
BAIDU_MAPS_MCP_ENABLED=false
BAIDU_MAPS_MCP_TRANSPORT=stdio
BAIDU_MAPS_MCP_URL=
BAIDU_MAPS_MCP_COMMAND=
BAIDU_MAPS_API_KEY=

TUNIU_MCP_ENABLED=false
TUNIU_MCP_TRANSPORT=stdio
TUNIU_MCP_URL=
TUNIU_MCP_COMMAND=
TUNIU_API_KEY=

# Firecrawl MCP adds fresh webpage evidence for attractions, openings, and bookings.
FIRECRAWL_MCP_ENABLED=false
FIRECRAWL_MCP_TRANSPORT=http
FIRECRAWL_MCP_URL=https://mcp.firecrawl.dev/{FIRECRAWL_API_KEY}/v2/mcp
FIRECRAWL_MCP_COMMAND=

# Tavily MCP can run alongside Firecrawl for search/extract/map/crawl evidence.
TAVILY_MCP_ENABLED=false
TAVILY_MCP_TRANSPORT=http
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey={TAVILY_API_KEY}
TAVILY_MCP_COMMAND=
